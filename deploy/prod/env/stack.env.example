# Stack-level deploy variables used by the local-manager CD flow.
STACK_NAME=onlineoj-prod
STACK_IMAGE_TAG=sha-REPLACE_ME
STACK_REGISTRY=local-build

WEB_IMAGE=syncode-web:sha-REPLACE_ME
APP_IMAGE=syncode-app:sha-REPLACE_ME
ADMIN_IMAGE=syncode-admin:sha-REPLACE_ME

GATEWAY_IMAGE=oj-gateway:sha-REPLACE_ME
SYSTEM_IMAGE=oj-system:sha-REPLACE_ME
FRIEND_IMAGE=oj-friend:sha-REPLACE_ME
JOB_IMAGE=oj-job:sha-REPLACE_ME
JUDGE_IMAGE=oj-judge:sha-REPLACE_ME
AGENT_IMAGE=oj-agent:sha-REPLACE_ME

PUBLIC_DOMAIN=oj.example.com
MANAGER_PUBLIC_IP=101.96.200.76
WORKER_PUBLIC_IP=101.96.200.77
WORKER_SSH_HOST=101.96.200.77
WORKER_SSH_USER=root
WORKER_SSH_PORT=22
WORKER_IMAGE_LIST=oj-agent:sha-REPLACE_ME oj-judge:sha-REPLACE_ME

DOCKER_SOCKET_PATH=/var/run/docker.sock
JUDGE_HOST_USER_CODE_DIR=/app/user-code
JUDGE_HOST_USER_CODE_POOL_DIR=/app/user-code-pool

MANAGER_CONSTRAINT=node.role==manager
WORKER_CONSTRAINT=node.hostname==iv-yeivf9a8sgobzsynlbka
