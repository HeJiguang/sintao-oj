{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@aioj/api": ["packages/api/src/index.ts"],
      "@aioj/api/*": ["packages/api/src/*"],
      "@aioj/config": ["packages/config/src/index.ts"],
      "@aioj/config/*": ["packages/config/src/*"],
      "@aioj/tokens": ["packages/tokens/src/index.css"],
      "@aioj/ui": ["packages/ui/src/index.ts"],
      "@aioj/ui/*": ["packages/ui/src/*"]
    }
  }
}
