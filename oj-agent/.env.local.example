# Local-first example for running oj-agent without Nacos.
# Keep Nacos disabled locally. Cloud deployment can override these through env vars.
OJ_AGENT_PORT=8016

OJ_AGENT_NACOS_CONFIG_ENABLED=false
OJ_AGENT_NACOS_SERVER_ADDR=
OJ_AGENT_NACOS_NAMESPACE=
OJ_AGENT_NACOS_GROUP=DEFAULT_GROUP
OJ_AGENT_NACOS_CONFIG_DATA_ID=oj-agent-local.yaml
OJ_AGENT_NACOS_USERNAME=nacos
OJ_AGENT_NACOS_PASSWORD=

OJ_AGENT_NACOS_ENABLED=false
OJ_AGENT_NACOS_SERVICE_NAME=oj-agent
OJ_AGENT_NACOS_PORT=8016
OJ_AGENT_NACOS_IP=127.0.0.1

# Required for real LLM-backed planning.
OJ_AGENT_LLM_PROVIDER=openai_compatible
OJ_AGENT_LLM_BASE_URL=https://api.deepseek.com/v1
OJ_AGENT_LLM_API_KEY=replace-with-your-key
OJ_AGENT_CHAT_MODEL=deepseek-chat
OJ_AGENT_TRAINING_MODEL=deepseek-chat

# Local pressure-test defaults: keep optional retrieval pieces off unless needed.
OJ_AGENT_RAG_ENABLED=false
OJ_AGENT_RAG_DOC_GLOBS=
OJ_AGENT_RAG_TOP_K=3
OJ_AGENT_RAG_MAX_SNIPPET_CHARS=420

OJ_AGENT_QDRANT_ENABLED=false
OJ_AGENT_QDRANT_URL=http://127.0.0.1:6333
OJ_AGENT_QDRANT_API_KEY=
OJ_AGENT_QDRANT_COLLECTION=oj-agent-knowledge
OJ_AGENT_QDRANT_TOP_K=3
OJ_AGENT_QDRANT_CHUNK_SIZE=240

OJ_AGENT_GATEWAY_USER_ID_HEADER=X-User-Id

# Runtime persistence defaults to local files + in-memory stores.
OJ_AGENT_RUNTIME_DATA_DIR=
OJ_AGENT_TRACE_STORE=memory
OJ_AGENT_QUERY_LEDGER_STORE=memory
OJ_AGENT_EVALUATION_STORE=memory
