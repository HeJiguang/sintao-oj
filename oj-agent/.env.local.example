# Copy this file to `oj-agent/.env.local` and fill your real values locally.
# Do not commit the real `.env.local`.

OJ_AGENT_LLM_PROVIDER=openai_compatible
OJ_AGENT_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OJ_AGENT_LLM_API_KEY=replace_with_your_new_dashscope_key
OJ_AGENT_CHAT_MODEL=qwen-turbo
OJ_AGENT_TRAINING_MODEL=qwen-plus
OJ_AGENT_LLM_TIMEOUT_SECONDS=30
OJ_AGENT_LLM_TEMPERATURE=0.2
OJ_AGENT_LLM_MAX_TOKENS=1200
OJ_AGENT_LLM_FALLBACK_ENABLED=true
OJ_AGENT_PORT=8015

# Local quick-start mode:
# - Keep Nacos disabled
# - Let gateway/friend call http://127.0.0.1:8015 directly
OJ_AGENT_NACOS_ENABLED=false
OJ_AGENT_NACOS_SERVICE_NAME=oj-agent
OJ_AGENT_NACOS_PORT=8015
